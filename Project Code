#### PAYOFF #######

library(dplyr)
library(lme4)


df <- df2 %>%
  distinct(
    interaction, pairing_id, round, agent_id, move,
    model_1, model_2, payoff_agent_1, payoff_agent_2
  ) %>%
  mutate(
    focal_model = if_else(agent_id == "Adaptive_0_0", model_1, model_2),
    opponent_model = if_else(agent_id == "Adaptive_0_0", model_2, model_1),
    cooperate = if_else(tolower(move) == "cooperate", 1, 0),
    payoff = if_else(agent_id == "Adaptive_0_0", payoff_agent_1, payoff_agent_2),
    pairing_uid = paste(interaction, pairing_id, sep = "_")
  )



m_payoff_models <- lmer(
  payoff ~ focal_model * opponent_model + scale(round) + (1 | pairing_uid),
  data = df
)

drop1(m_payoff_models, test = "Chisq")
summary(m_payoff_models)
anova(m_payoff_models)


