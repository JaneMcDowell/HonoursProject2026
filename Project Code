  )

df_opp <- df %>%
  select(pair_uid, round, agent_id, cooperate) %>%
  rename(
    opponent_agent_id = agent_id,
    opponent_cooperate = cooperate
  )

# Adding lagged behaviour
df2 <- df %>%
  left_join(
    df_opp,
    by = c("pair_uid", "round"),
    relationship = "many-to-many"
  ) %>%
  filter(agent_id != opponent_agent_id) %>%
  select(-opponent_agent_id)

df2 <- df2 %>%
  arrange(pair_uid, agent_id, round) %>%
  group_by(pair_uid, agent_id) %>%
  mutate(
    own_prev_move = lag(cooperate),
    opp_prev_move = lag(opponent_cooperate)
  ) %>%
  ungroup()

