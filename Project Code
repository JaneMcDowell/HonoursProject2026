###### COMMUNICATION - TRUST SIGNAL RATE ###############

outcome_var <- "comm_trust_signal_rate"

# keep only non-missing rows for that behaviour
df_test <- pair_summary %>%
  select(focal_model, all_of(outcome_var)) %>%
  filter(!is.na(.data[[outcome_var]]))

# quick descriptives
df_test %>%
  group_by(focal_model) %>%
  summarise(
    n = n(),
    median = median(.data[[outcome_var]], na.rm = TRUE),
    mean = mean(.data[[outcome_var]], na.rm = TRUE),
    sd = sd(.data[[outcome_var]], na.rm = TRUE),
    min = min(.data[[outcome_var]], na.rm = TRUE),
    max = max(.data[[outcome_var]], na.rm = TRUE)
  )

# kruskal-wallis test
kw_result <- kruskal.test(
  as.formula(paste(outcome_var, "~ focal_model")),
  data = df_test
)

print(kw_result)

# epsilon-squared effect size
H <- as.numeric(kw_result$statistic)
k <- n_distinct(df_test$focal_model)
n <- nrow(df_test)

epsilon2 <- (H - k + 1) / (n - k)
epsilon2 <- max(0, epsilon2)

cat("Epsilon-squared =", round(epsilon2, 3), "\n")

# dunn post-hoc with Holm correction
dunn_result <- df_test %>%
  dunn_test(
    as.formula(paste(outcome_var, "~ focal_model")),
    p.adjust.method = "holm"
  )

print(dunn_result)

