read_one_interaction <- function(interaction_name, model1_name, model2_name, moves_path, thinking_path,
                                 thinking_contexts_to_use = c("move_decision")) {
  
  moves <- read_csv(moves_path, show_col_types = FALSE) %>%
    transmute(
      interaction = interaction_name,
      model1 = model1_name,
      model2 = model2_name,
      pairing_id,
      round,
      agent_id,
      move
    )
  
  thinking_raw <- read_csv(thinking_path, show_col_types = FALSE)
  
  if (!is.null(thinking_contexts_to_use)) {
    thinking_raw <- thinking_raw %>%
      filter(context %in% thinking_contexts_to_use)
  }
  
  thinking <- thinking_raw %>%
    group_by(pairing_id, round, agent_id) %>%
    summarise(
      thinking_context = paste(sort(unique(context)), collapse = " || "),
      thinking_text = str_squish(paste(thinking, collapse = " ")),
      .groups = "drop"
    )
  
  moves %>%
    left_join(thinking, by = c("pairing_id", "round", "agent_id")) %>%
    mutate(
      focal_model = case_when(
        agent_id == "Adaptive_0_0" ~ model1,
        agent_id == "Adaptive_1_0" ~ model2,
        TRUE ~ NA_character_
      ),
      opponent_model = case_when(
        agent_id == "Adaptive_0_0" ~ model2,
        agent_id == "Adaptive_1_0" ~ model1,
        TRUE ~ NA_character_
      )
    )
}

